{
  "name": "axess-gy-auth",
  "version": "1.0.0",
  "description": "Auth Worker for Axess GY Dashboard (JWT issuer backed by Cloudflare KV).",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "seed": "node seed-users.js",
    "kv:list": "wrangler kv key list --binding USERS",
    "kv:get": "wrangler kv key get --binding USERS",
    "kv:delete": "wrangler kv key delete --binding USERS",
    "secret:jwt": "wrangler secret put JWT_SECRET"
  },
  "devDependencies": {
    "wrangler": "^3.80.0"
  }
}
